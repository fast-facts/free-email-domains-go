{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:base"
    ],
    "minimumReleaseAge": "14 days",
    "schedule": [
        "before 4am"
    ],
    "timezone": "America/New_York",
    "prCreation": "immediate",
    "labels": [
        "dependencies"
    ],
    "rangeStrategy": "bump",
    "automerge": true,
    "automergeType": "pr"
}